# ─────────────────────────────────────────────────────────────
#  EV Route Optimizer — Environment Variables
#  Copy this file to .env and fill in your values.
#  .env is in .gitignore — never commit real keys!
# ─────────────────────────────────────────────────────────────

# Flask server settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# ── Overpass API ──────────────────────────────────────────────
# The public endpoint is used by default (no key required).
# If you have a private Overpass instance, set it here.
# OVERPASS_URL=https://overpass-api.de/api/interpreter

# ── Nominatim (geocoding) ─────────────────────────────────────
# Public Nominatim requires only a User-Agent — no key needed.
# For production use, run your own instance or use a commercial
# provider (e.g. Geoapify, LocationIQ) and set the key below.
# NOMINATIM_BASE=https://nominatim.openstreetmap.org
# NOMINATIM_API_KEY=

# ── Mapbox (optional — if you switch from OSM tiles) ─────────
# Free tier: 50,000 map loads/month.
# Sign up at https://account.mapbox.com/
# MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX0tFWSJ9...

# ── CORS (production hardening) ───────────────────────────────
# Restrict which origins can call the API.
# CORS_ORIGINS=https://your-frontend-domain.com
